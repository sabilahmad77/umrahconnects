// ============================================================
// Umrah Connects — Prisma Schema
// PostgreSQL 16 · Row-Level Security enabled per-table
// All money: bigint minor units + currency code (no floats)
// All timestamps: timestamptz stored UTC
// All tenant-scoped tables: non-null tenant_id
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  // native = local dev; debian target = Render/Docker (node:20 bookworm, openssl 3)
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "marketplace", "social", "audit", "plugin_crm", "plugin_booking", "plugin_hotel", "plugin_visa", "plugin_transport", "plugin_finance", "plugin_group_ops", "plugin_portal", "plugin_reporting"]
}

// ============================================================
// ENUMS
// ============================================================

enum TenantStatus {
  PENDING_KYC
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  ACTIVE
  SUSPENDED
  CHURNED

  @@schema("core")
}

enum TenantTier {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE

  @@schema("core")
}

enum TenantType {
  OPERATOR            // Licensed Umrah/Hajj operator
  MU_ASSASA           // Saudi-licensed ground operator
  SUB_AGENT           // Sub-agent under an operator
  VENDOR_HOTEL
  VENDOR_TRANSPORT
  VENDOR_CATERING
  VENDOR_GUIDE
  VENDOR_VISA

  @@schema("core")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING_VERIFICATION

  @@schema("core")
}

enum Gender {
  MALE
  FEMALE

  @@schema("core")
}

enum PilgrimStatus {
  LEAD
  PROSPECT
  BOOKED
  DOCUMENTS_PENDING
  VISA_PENDING
  VISA_APPROVED
  VISA_REJECTED
  TRAVELING
  IN_KINGDOM
  RETURNED
  CANCELLED

  @@schema("plugin_crm")
}

enum BookingStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  FULLY_PAID
  VISA_PROCESSING
  TRAVELING
  COMPLETED
  CANCELLED
  REFUNDED

  @@schema("plugin_booking")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED

  @@schema("plugin_finance")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  VOID

  @@schema("plugin_finance")
}

enum VisaStatus {
  NOT_STARTED
  DOCUMENTS_COLLECTING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED

  @@schema("plugin_visa")
}

enum RegulatorySystem {
  NUSUK_MASAR
  SISKOPATUH
  NAHCON
  DIYANET
  TABUNG_HAJI
  MOTAC
  IBA_DGRP
  MANUAL

  @@schema("plugin_visa")
}

enum HotelContractType {
  ALLOTMENT
  ON_DEMAND
  GUARANTEED

  @@schema("plugin_hotel")
}

enum TransportType {
  BUS_SMALL         // Hiace/Coaster
  BUS_MEDIUM        // 30-seat
  BUS_LARGE         // 50-seat
  PRIVATE_CAR
  VAN

  @@schema("plugin_transport")
}

enum MovementType {
  AIRPORT_PICKUP
  AIRPORT_DROPOFF
  MAKKAH_MADINAH
  MADINAH_MAKKAH
  ZIYARAT
  MASHAER_MINA
  MASHAER_ARAFAT
  MASHAER_MUZDALIFAH
  LOCAL

  @@schema("plugin_transport")
}

enum VendorStatus {
  PENDING_KYC
  KYC_SUBMITTED
  VERIFIED
  SUSPENDED
  DELISTED

  @@schema("marketplace")
}

enum PostType {
  UPDATE
  OFFER
  GUIDELINE
  QUESTION
  PARTNERSHIP
  STORY
  EVENT

  @@schema("social")
}

enum PostVisibility {
  PUBLIC
  VERIFIED_ONLY
  ROLE_SET
  FOLLOWER_SET
  CUSTOM_SET

  @@schema("social")
}

enum ModerationStatus {
  PENDING
  APPROVED
  HELD_FOR_REVIEW
  REJECTED
  SHADOW_BANNED

  @@schema("social")
}

enum SocialAccountType {
  OPERATOR
  SUB_AGENT
  VENDOR_HOTEL
  VENDOR_TRANSPORT
  VENDOR_CATERING
  MUTAWIF
  VISA_PROCESSOR
  PILGRIM

  @@schema("social")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SOFT_DELETE
  LOGIN
  LOGOUT
  PERMISSION_CHANGE
  TENANT_CONFIG_CHANGE
  PAYMENT_INITIATE
  PAYMENT_COMPLETE
  PAYMENT_FAIL
  VISA_SUBMIT
  VISA_STATUS_CHANGE
  DOCUMENT_UPLOAD
  DOCUMENT_DELETE
  DATA_EXPORT
  DATA_ACCESS

  @@schema("audit")
}

// ============================================================
// CORE SCHEMA — Tenant, User, RBAC
// ============================================================

model Tenant {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String       @unique @db.VarChar(100)
  name             String       @db.VarChar(255)
  nameAr           String?      @db.VarChar(255) @map("name_ar")
  type             TenantType
  status           TenantStatus @default(PENDING_KYC)
  tier             TenantTier   @default(STARTER)

  // Licensing
  licenseNumber    String?      @db.VarChar(100) @map("license_number")
  licenseCountry   String?      @db.Char(2)      @map("license_country")
  licenseExpiry    DateTime?    @db.Date         @map("license_expiry")
  regulatorySystem RegulatorySystem? @map("regulatory_system")

  // Contact
  email            String       @db.VarChar(255)
  phone            String?      @db.VarChar(30)
  website          String?      @db.VarChar(255)
  country          String       @db.Char(2)
  timezone         String       @default("Asia/Riyadh") @db.VarChar(50)
  locale           String       @default("en") @db.VarChar(10)
  currency         String       @default("SAR") @db.Char(3)

  // Hierarchy
  parentTenantId   String?      @db.Uuid @map("parent_tenant_id")
  parentTenant     Tenant?      @relation("SubTenants", fields: [parentTenantId], references: [id])
  subTenants       Tenant[]     @relation("SubTenants")

  // Metadata
  metadata         Json?        @db.JsonB
  settings         Json         @default("{}") @db.JsonB
  createdAt        DateTime     @default(now()) @db.Timestamptz @map("created_at")
  updatedAt        DateTime     @updatedAt @db.Timestamptz @map("updated_at")
  deletedAt        DateTime?    @db.Timestamptz @map("deleted_at")

  // Relations
  users            User[]
  roles            Role[]
  kycRecords       TenantKyc[]
  pluginInstalls   TenantPlugin[]

  @@map("tenants")
  @@schema("core")
}

model TenantKyc {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])

  registrySource   RegulatorySystem @map("registry_source")
  registryLookupAt DateTime? @db.Timestamptz @map("registry_lookup_at")
  registryData     Json?     @db.JsonB @map("registry_data")
  verifiedAt       DateTime? @db.Timestamptz @map("verified_at")
  verifiedBy       String?   @db.Uuid @map("verified_by")
  rejectionReason  String?   @map("rejection_reason")
  documents        Json      @default("[]") @db.JsonB

  createdAt        DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt        DateTime  @updatedAt @db.Timestamptz @map("updated_at")

  @@map("tenant_kyc")
  @@schema("core")
}

model User {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String     @db.Uuid @map("tenant_id")
  tenant           Tenant     @relation(fields: [tenantId], references: [id])

  email            String?    @db.VarChar(255)
  phone            String?    @db.VarChar(30)
  passwordHash     String?    @map("password_hash")
  status           UserStatus @default(PENDING_VERIFICATION)

  // Profile
  firstName        String     @db.VarChar(100) @map("first_name")
  lastName         String     @db.VarChar(100) @map("last_name")
  firstNameAr      String?    @db.VarChar(100) @map("first_name_ar")
  lastNameAr       String?    @db.VarChar(100) @map("last_name_ar")
  avatarUrl        String?    @map("avatar_url")
  locale           String     @default("en") @db.VarChar(10)
  timezone         String     @default("Asia/Riyadh") @db.VarChar(50)

  // Auth
  mfaEnabled       Boolean    @default(false) @map("mfa_enabled")
  mfaSecret        String?    @map("mfa_secret")
  emailVerifiedAt  DateTime?  @db.Timestamptz @map("email_verified_at")
  phoneVerifiedAt  DateTime?  @db.Timestamptz @map("phone_verified_at")
  lastLoginAt      DateTime?  @db.Timestamptz @map("last_login_at")
  lastLoginIp      String?    @map("last_login_ip")
  loginCount       Int        @default(0) @map("login_count")

  createdAt        DateTime   @default(now()) @db.Timestamptz @map("created_at")
  updatedAt        DateTime   @updatedAt @db.Timestamptz @map("updated_at")
  createdBy        String?    @db.Uuid @map("created_by")
  deletedAt        DateTime?  @db.Timestamptz @map("deleted_at")
  rowVersion       Int        @default(1) @map("row_version")

  // Relations
  userRoles        UserRole[]
  refreshTokens    RefreshToken[]
  otpCodes         OtpCode[]
  socialAccount    SocialAccount?

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([email])
  @@map("users")
  @@schema("core")
}

model RefreshToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @db.Timestamptz @map("expires_at")
  revokedAt  DateTime? @db.Timestamptz @map("revoked_at")
  createdAt  DateTime @default(now()) @db.Timestamptz @map("created_at")
  userAgent  String?  @map("user_agent")
  ipAddress  String?  @map("ip_address")

  @@index([userId])
  @@map("refresh_tokens")
  @@schema("core")
}

model OtpCode {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @db.Uuid @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       String?
  email       String?
  codeHash    String   @map("code_hash")
  purpose     String   @db.VarChar(50)  // phone_verify, login, password_reset
  expiresAt   DateTime @db.Timestamptz @map("expires_at")
  usedAt      DateTime? @db.Timestamptz @map("used_at")
  attempts    Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@index([phone])
  @@index([email])
  @@map("otp_codes")
  @@schema("core")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String?  @db.Uuid @map("tenant_id")   // null = platform-wide role
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  name        String   @db.VarChar(100)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")   // platform-defined, not deletable
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz @map("updated_at")

  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
  @@schema("core")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Format: plugin:resource:action  e.g. crm:pilgrim:read
  namespace   String   @db.VarChar(50)
  resource    String   @db.VarChar(100)
  action      String   @db.VarChar(50)
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")

  rolePermissions RolePermission[]

  @@unique([namespace, resource, action])
  @@map("permissions")
  @@schema("core")
}

model RolePermission {
  roleId       String     @db.Uuid @map("role_id")
  permissionId String     @db.Uuid @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedAt    DateTime   @default(now()) @db.Timestamptz @map("granted_at")
  grantedBy    String?    @db.Uuid @map("granted_by")

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("core")
}

model UserRole {
  userId    String   @db.Uuid @map("user_id")
  roleId    String   @db.Uuid @map("role_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now()) @db.Timestamptz @map("granted_at")
  grantedBy String?  @db.Uuid @map("granted_by")
  expiresAt DateTime? @db.Timestamptz @map("expires_at")

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("core")
}

model TenantPlugin {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  pluginId    String   @db.VarChar(100) @map("plugin_id")
  version     String   @db.VarChar(20)
  enabled     Boolean  @default(true)
  config      Json     @default("{}") @db.JsonB
  installedAt DateTime @default(now()) @db.Timestamptz @map("installed_at")
  installedBy String?  @db.Uuid @map("installed_by")
  updatedAt   DateTime @updatedAt @db.Timestamptz @map("updated_at")

  @@unique([tenantId, pluginId])
  @@map("tenant_plugins")
  @@schema("core")
}

// ============================================================
// PLUGIN: CRM — Pilgrims, Leads, Family Groups
// ============================================================

model Pilgrim {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String        @db.Uuid @map("tenant_id")
  status           PilgrimStatus @default(LEAD)

  // Personal
  firstNameEn      String        @db.VarChar(100) @map("first_name_en")
  lastNameEn       String        @db.VarChar(100) @map("last_name_en")
  firstNameAr      String?       @db.VarChar(100) @map("first_name_ar")
  lastNameAr       String?       @db.VarChar(100) @map("last_name_ar")
  gender           Gender
  dateOfBirth      DateTime      @db.Date @map("date_of_birth")
  nationality      String        @db.Char(2)

  // Contact
  email            String?       @db.VarChar(255)
  phone            String?       @db.VarChar(30)
  whatsapp         String?       @db.VarChar(30)
  address          String?
  city             String?       @db.VarChar(100)
  country          String        @db.Char(2)
  preferredLanguage String       @default("ar") @db.VarChar(10) @map("preferred_language")

  // Passport / ID
  passportNumber   String?       @db.VarChar(30) @map("passport_number")  // encrypted
  passportExpiry   DateTime?     @db.Date @map("passport_expiry")
  passportCountry  String?       @db.Char(2) @map("passport_country")
  nationalId       String?       @db.VarChar(30) @map("national_id")      // encrypted

  // Medical / accessibility
  hasDisability    Boolean       @default(false) @map("has_disability")
  needsWheelchair  Boolean       @default(false) @map("needs_wheelchair")
  medicalNotes     String?       @map("medical_notes")
  vaccinated       Boolean       @default(false)
  vaccinationRecords Json        @default("[]") @db.JsonB @map("vaccination_records")

  // CRM
  source           String?       @db.VarChar(100) // sub_agent_id, marketing_channel, referral
  subAgentId       String?       @db.Uuid @map("sub_agent_id")
  notes            String?
  tags             String[]

  // Stats
  priorUmrahCount  Int           @default(0) @map("prior_umrah_count")
  priorHajjCount   Int           @default(0) @map("prior_hajj_count")
  lifetimeSpend    BigInt        @default(0) @map("lifetime_spend")  // minor units SAR
  lifetimeCurrency String        @default("SAR") @db.Char(3) @map("lifetime_currency")

  // Family
  familyGroupId    String?       @db.Uuid @map("family_group_id")
  familyGroup      FamilyGroup?  @relation(fields: [familyGroupId], references: [id])
  mahramId         String?       @db.Uuid @map("mahram_id")    // for female pilgrims

  createdAt        DateTime      @default(now()) @db.Timestamptz @map("created_at")
  updatedAt        DateTime      @updatedAt @db.Timestamptz @map("updated_at")
  createdBy        String?       @db.Uuid @map("created_by")
  updatedBy        String?       @db.Uuid @map("updated_by")
  deletedAt        DateTime?     @db.Timestamptz @map("deleted_at")
  rowVersion       Int           @default(1) @map("row_version")

  documents        PilgrimDocument[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, familyGroupId])
  @@map("pilgrims")
  @@schema("plugin_crm")
}

model FamilyGroup {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid @map("tenant_id")
  name        String    @db.VarChar(200)
  leadPilgrimId String? @db.Uuid @map("lead_pilgrim_id")
  notes       String?
  createdAt   DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt   DateTime  @updatedAt @db.Timestamptz @map("updated_at")

  pilgrims    Pilgrim[]

  @@index([tenantId])
  @@map("family_groups")
  @@schema("plugin_crm")
}

model PilgrimDocument {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid @map("tenant_id")
  pilgrimId    String   @db.Uuid @map("pilgrim_id")
  pilgrim      Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)

  type         String   @db.VarChar(50) // passport, visa, vaccination, mahram_cert, photo
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")       // S3 key
  mimeType     String   @map("mime_type")
  fileSizeBytes Int     @map("file_size_bytes")
  ocrData      Json?    @db.JsonB @map("ocr_data")
  verified     Boolean  @default(false)
  verifiedAt   DateTime? @db.Timestamptz @map("verified_at")
  verifiedBy   String?  @db.Uuid @map("verified_by")
  expiresAt    DateTime? @db.Date @map("expires_at")
  version      Int      @default(1)

  createdAt    DateTime @default(now()) @db.Timestamptz @map("created_at")
  createdBy    String?  @db.Uuid @map("created_by")

  @@index([tenantId, pilgrimId])
  @@map("pilgrim_documents")
  @@schema("plugin_crm")
}

// ============================================================
// PLUGIN: BOOKING — Packages, Bookings, Payments
// ============================================================

model Package {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid @map("tenant_id")
  name            String   @db.VarChar(255)
  nameAr          String?  @db.VarChar(255) @map("name_ar")
  description     String?
  descriptionAr   String?  @map("description_ar")
  tier            String   @db.VarChar(50) @default("STANDARD") // ECONOMY/STANDARD/PREMIUM/VIP
  tripType        String   @db.VarChar(20)  // UMRAH / HAJJ
  durationDays    Int      @map("duration_days")

  // Travel dates
  departureDate   DateTime? @db.Date @map("departure_date")
  returnDate      DateTime? @db.Date @map("return_date")

  // Pricing (bigint minor units)
  basePriceCents  BigInt   @map("base_price_cents")
  currency        String   @db.Char(3) @default("SAR")
  maxCapacity     Int      @map("max_capacity")
  bookedCount     Int      @default(0) @map("booked_count")

  // Composition (services included)
  includes        Json     @default("{}") @db.JsonB  // visa, flight, hotel_makkah, hotel_madinah, transport, meals, guide
  pricingRules    Json     @default("[]") @db.JsonB  // seasonal multipliers, early-bird discounts

  isPublished     Boolean  @default(false) @map("is_published")
  createdAt       DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime @updatedAt @db.Timestamptz @map("updated_at")
  createdBy       String?  @db.Uuid @map("created_by")
  deletedAt       DateTime? @db.Timestamptz @map("deleted_at")

  bookings        Booking[]

  @@index([tenantId])
  @@map("packages")
  @@schema("plugin_booking")
}

model Booking {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String        @db.Uuid @map("tenant_id")
  bookingRef      String        @unique @map("booking_ref")  // UC-2026-00001
  packageId       String?       @db.Uuid @map("package_id")
  package         Package?      @relation(fields: [packageId], references: [id])
  status          BookingStatus @default(DRAFT)

  // Origination
  subAgentId      String?       @db.Uuid @map("sub_agent_id")
  subAgentCommissionRate Decimal? @db.Decimal(5,2) @map("sub_agent_commission_rate")

  // Pricing snapshot (at time of booking)
  totalAmountCents  BigInt      @map("total_amount_cents")
  paidAmountCents   BigInt      @default(0) @map("paid_amount_cents")
  currency          String      @db.Char(3) @default("SAR")
  discountCents     BigInt      @default(0) @map("discount_cents")
  taxCents          BigInt      @default(0) @map("tax_cents")

  // Travel
  groupId         String?       @db.Uuid @map("group_id")
  departureDate   DateTime?     @db.Date @map("departure_date")
  returnDate      DateTime?     @db.Date @map("return_date")
  flightDetails   Json?         @db.JsonB @map("flight_details")

  notes           String?
  cancellationReason String?    @map("cancellation_reason")
  cancelledAt     DateTime?     @db.Timestamptz @map("cancelled_at")

  createdAt       DateTime      @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime      @updatedAt @db.Timestamptz @map("updated_at")
  createdBy       String?       @db.Uuid @map("created_by")
  updatedBy       String?       @db.Uuid @map("updated_by")
  rowVersion      Int           @default(1) @map("row_version")

  pilgrims        BookingPilgrim[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([bookingRef])
  @@map("bookings")
  @@schema("plugin_booking")
}

model BookingPilgrim {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  bookingId   String   @db.Uuid @map("booking_id")
  booking     Booking  @relation(fields: [bookingId], references: [id])
  pilgrimId   String   @db.Uuid @map("pilgrim_id")

  // Per-pilgrim pricing override
  priceCents  BigInt?  @map("price_cents")
  currency    String?  @db.Char(3)
  roomType    String?  @db.VarChar(50) @map("room_type")
  bedType     String?  @db.VarChar(30) @map("bed_type")
  seatNumber  String?  @db.VarChar(20) @map("seat_number")
  mealPref    String?  @db.VarChar(50) @map("meal_pref")
  specialReqs String?  @map("special_reqs")

  addedAt     DateTime @default(now()) @db.Timestamptz @map("added_at")

  @@unique([bookingId, pilgrimId])
  @@index([tenantId])
  @@map("booking_pilgrims")
  @@schema("plugin_booking")
}

// ============================================================
// PLUGIN: HOTEL INVENTORY
// ============================================================

model Hotel {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String?  @db.Uuid @map("tenant_id")  // null = marketplace-wide
  vendorId         String?  @db.Uuid @map("vendor_id")

  name             String   @db.VarChar(255)
  nameAr           String?  @db.VarChar(255) @map("name_ar")
  city             String   @db.VarChar(100)  // MAKKAH / MADINAH / JEDDAH
  country          String   @db.Char(2) @default("SA")
  area             String?  @db.VarChar(120)              // district / neighbourhood
  address          String?
  postalCode       String?  @db.VarChar(20) @map("postal_code")
  starRating       Int?     @map("star_rating")
  distanceToHaram  Int?     @map("distance_to_haram")  // meters
  coordinates      Json?    @db.JsonB
  amenities        String[]
  images           String[]
  description      String?
  descriptionAr    String?  @map("description_ar")

  // Contact + operations
  contactPerson    String?  @db.VarChar(150) @map("contact_person")
  phone            String?  @db.VarChar(40)
  email            String?  @db.VarChar(255)
  checkInTime      String?  @db.VarChar(10) @map("check_in_time")    // "15:00"
  checkOutTime     String?  @db.VarChar(10) @map("check_out_time")   // "12:00"
  cancellationPolicy String? @map("cancellation_policy")
  totalRooms       Int      @default(0) @map("total_rooms")
  status           String   @db.VarChar(20) @default("ACTIVE")  // ACTIVE / INACTIVE / MAINTENANCE
  notes            String?
  isVerified       Boolean  @default(false) @map("is_verified")

  createdAt        DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt        DateTime @updatedAt @db.Timestamptz @map("updated_at")

  roomTypes        RoomType[]
  allotments       Allotment[]
  rooms            Room[]
  hotelBookings    HotelBooking[]

  @@index([tenantId])
  @@index([city])
  @@index([tenantId, status])
  @@map("hotels")
  @@schema("plugin_hotel")
}

model RoomType {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId       String   @db.Uuid @map("hotel_id")
  hotel         Hotel    @relation(fields: [hotelId], references: [id])
  name          String   @db.VarChar(100)
  occupancy     Int      // 1=single, 2=double, 3=triple, 4=quad
  bedConfig     String?  @db.VarChar(50) @map("bed_config")
  description   String?
  basePriceCents BigInt  @default(0) @map("base_price_cents")    // per room per night
  pricePerPersonCents BigInt? @map("price_per_person_cents")
  totalCount    Int      @default(0) @map("total_count")          // number of rooms of this type
  status        String   @db.VarChar(20) @default("ACTIVE")
  amenities     String[]
  images        String[]

  rooms         Room[]

  @@index([hotelId])
  @@map("room_types")
  @@schema("plugin_hotel")
}

model Room {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid @map("tenant_id")
  hotelId       String    @db.Uuid @map("hotel_id")
  hotel         Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomTypeId    String?   @db.Uuid @map("room_type_id")
  roomType      RoomType? @relation(fields: [roomTypeId], references: [id])
  roomNumber    String    @db.VarChar(40) @map("room_number")
  floor         String?   @db.VarChar(20)
  capacity      Int       @default(2)
  bedType       String?   @db.VarChar(40) @map("bed_type")
  bedCount      Int       @default(1) @map("bed_count")
  availableBeds Int       @default(0) @map("available_beds")
  pricePerNightCents BigInt @default(0) @map("price_per_night_cents")
  pricePerPersonCents BigInt? @map("price_per_person_cents")
  seasonalPricing Json    @default("[]") @db.JsonB @map("seasonal_pricing")
  images        String[]
  facilities    String[]
  description   String?
  status        String    @db.VarChar(20) @default("AVAILABLE")  // AVAILABLE / OCCUPIED / MAINTENANCE / INACTIVE
  notes         String?

  createdAt     DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @db.Timestamptz @map("updated_at")

  @@index([hotelId])
  @@index([hotelId, status])
  @@map("rooms")
  @@schema("plugin_hotel")
}

model HotelBooking {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid @map("tenant_id")
  hotelId       String    @db.Uuid @map("hotel_id")
  hotel         Hotel     @relation(fields: [hotelId], references: [id])
  roomTypeId    String?   @db.Uuid @map("room_type_id")
  roomId        String?   @db.Uuid @map("room_id")

  // Guest — platform user OR external
  customerUserId String?  @db.Uuid @map("customer_user_id")
  guestName     String    @db.VarChar(200) @map("guest_name")
  guestEmail    String?   @db.VarChar(255) @map("guest_email")
  guestPhone    String?   @db.VarChar(40) @map("guest_phone")
  guestNationality String? @db.Char(2) @map("guest_nationality")
  source        String    @db.VarChar(20) @default("EXTERNAL")  // PLATFORM_USER / EXTERNAL / OPERATOR / MARKETPLACE

  checkIn       DateTime  @db.Date @map("check_in")
  checkOut      DateTime  @db.Date @map("check_out")
  guests        Int       @default(1)
  totalAmountCents BigInt @default(0) @map("total_amount_cents")
  currency      String    @default("SAR") @db.VarChar(8)
  status        String    @db.VarChar(20) @default("PENDING")  // PENDING / CONFIRMED / CHECKED_IN / CHECKED_OUT / COMPLETED / CANCELLED
  paymentStatus String    @db.VarChar(20) @default("UNPAID") @map("payment_status")  // UNPAID / PARTIAL / PAID / REFUNDED
  notes         String?

  createdAt     DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt     DateTime  @updatedAt @db.Timestamptz @map("updated_at")

  @@index([tenantId])
  @@index([hotelId, status])
  @@index([tenantId, checkIn])
  @@map("hotel_bookings")
  @@schema("plugin_hotel")
}

model Allotment {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String            @db.Uuid @map("tenant_id")
  hotelId         String            @db.Uuid @map("hotel_id")
  hotel           Hotel             @relation(fields: [hotelId], references: [id])
  roomTypeId      String?           @db.Uuid @map("room_type_id")
  contractType    HotelContractType @default(ALLOTMENT) @map("contract_type")

  checkIn         DateTime          @db.Date @map("check_in")
  checkOut        DateTime          @db.Date @map("check_out")
  totalRooms      Int               @map("total_rooms")
  bookedRooms     Int               @default(0) @map("booked_rooms")
  overbookBuffer  Int               @default(0) @map("overbook_buffer")

  // Pricing
  rateCents       BigInt            @map("rate_cents")   // per room per night
  currency        String            @db.Char(3) @default("SAR")
  cancellationPolicy Json           @default("{}") @db.JsonB @map("cancellation_policy")

  notes           String?
  createdAt       DateTime          @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime          @updatedAt @db.Timestamptz @map("updated_at")

  roomAssignments RoomAssignment[]

  @@index([tenantId])
  @@index([tenantId, checkIn, checkOut])
  @@map("allotments")
  @@schema("plugin_hotel")
}

model RoomAssignment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid @map("tenant_id")
  allotmentId   String   @db.Uuid @map("allotment_id")
  allotment     Allotment @relation(fields: [allotmentId], references: [id])
  bookingId     String   @db.Uuid @map("booking_id")
  roomNumber    String?  @db.VarChar(20) @map("room_number")
  pilgrims      Json     @default("[]") @db.JsonB  // pilgrim IDs
  checkIn       DateTime @db.Date @map("check_in")
  checkOut      DateTime @db.Date @map("check_out")
  confirmedAt   DateTime? @db.Timestamptz @map("confirmed_at")

  @@index([tenantId])
  @@index([allotmentId])
  @@map("room_assignments")
  @@schema("plugin_hotel")
}

// ============================================================
// PLUGIN: VISA & COMPLIANCE
// ============================================================

model VisaApplication {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String           @db.Uuid @map("tenant_id")
  pilgrimId       String?          @db.Uuid @map("pilgrim_id")
  bookingId       String?          @db.Uuid @map("booking_id")
  operatorId      String?          @db.Uuid @map("operator_id")    // operator who submitted on behalf

  status          VisaStatus       @default(NOT_STARTED)
  regulatorySystem RegulatorySystem @map("regulatory_system")

  // Applicant snapshot (external applicants who are not platform pilgrims)
  applicantName       String?      @db.VarChar(200) @map("applicant_name")
  applicantPassport   String?      @db.VarChar(50) @map("applicant_passport")
  applicantNationality String?     @db.Char(2) @map("applicant_nationality")

  // Visa service detail
  visaType            String?      @db.VarChar(50) @map("visa_type")
  destinationCountry  String?      @db.Char(2) @map("destination_country")
  serviceCountry      String?      @db.Char(2) @map("service_country")
  applicationNumber   String?      @db.VarChar(60) @map("application_number")
  requiredDocuments   String[]     @map("required_documents")
  assignedOfficer     String?      @db.VarChar(150) @map("assigned_officer")
  expectedCompletionAt DateTime?   @db.Date @map("expected_completion_at")

  // Finance
  priceCents      BigInt           @default(0) @map("price_cents")
  currency        String           @default("SAR") @db.VarChar(8)
  paymentStatus   String           @db.VarChar(20) @default("UNPAID") @map("payment_status")

  submittedAt     DateTime?        @db.Timestamptz @map("submitted_at")
  approvedAt      DateTime?        @db.Timestamptz @map("approved_at")
  rejectedAt      DateTime?        @db.Timestamptz @map("rejected_at")
  expiresAt       DateTime?        @db.Date @map("expires_at")

  // Regulator response
  externalRef     String?          @db.VarChar(100) @map("external_ref")   // Nusuk/SISKOPATUH ref
  regulatorData   Json?            @db.JsonB @map("regulator_data")
  rejectionCode   String?          @db.VarChar(50) @map("rejection_code")
  rejectionReason String?          @map("rejection_reason")
  riskScore       Int?             @map("risk_score")  // AI-computed visa rejection risk

  documents       Json             @default("[]") @db.JsonB
  timeline        Json             @default("[]") @db.JsonB   // immutable event log
  notes           String?

  createdAt       DateTime         @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime         @updatedAt @db.Timestamptz @map("updated_at")
  createdBy       String?          @db.Uuid @map("created_by")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([pilgrimId])
  @@map("visa_applications")
  @@schema("plugin_visa")
}

model RegulatorySubmission {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String           @db.Uuid @map("tenant_id")
  regulatorySystem RegulatorySystem @map("regulatory_system")
  batchRef        String?          @db.VarChar(100) @map("batch_ref")
  pilgrimIds      String[]         @map("pilgrim_ids")

  submittedAt     DateTime?        @db.Timestamptz @map("submitted_at")
  acknowledgedAt  DateTime?        @db.Timestamptz @map("acknowledged_at")
  completedAt     DateTime?        @db.Timestamptz @map("completed_at")
  failedAt        DateTime?        @db.Timestamptz @map("failed_at")

  requestPayload  Json?            @db.JsonB @map("request_payload")
  responsePayload Json?            @db.JsonB @map("response_payload")
  errorDetails    Json?            @db.JsonB @map("error_details")

  createdAt       DateTime         @default(now()) @db.Timestamptz @map("created_at")

  @@index([tenantId])
  @@index([tenantId, regulatorySystem])
  @@map("regulatory_submissions")
  @@schema("plugin_visa")
}

// ============================================================
// PLUGIN: TRANSPORT
// ============================================================

model Vehicle {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String        @db.Uuid @map("tenant_id")
  vendorId        String?       @db.Uuid @map("vendor_id")
  type            TransportType
  name            String?       @db.VarChar(200)              // human-readable name
  brand           String?       @db.VarChar(100)
  plateNumber     String        @db.VarChar(30) @map("plate_number")
  registrationNumber String?    @db.VarChar(50) @map("registration_number")
  capacity        Int
  bookedSeats     Int           @default(0) @map("booked_seats")
  luggageCapacity Int?          @map("luggage_capacity")
  hasAc           Boolean       @default(true) @map("has_ac")
  licensedForHajj Boolean       @default(false) @map("licensed_for_hajj")
  saudiLicenseNo  String?       @db.VarChar(50) @map("saudi_license_no")
  model           String?       @db.VarChar(100)
  year            Int?
  features        String[]
  imageUrls       String[]      @map("image_urls")
  documentUrls    String[]      @map("document_urls")
  status          String        @db.VarChar(20) @default("AVAILABLE")  // AVAILABLE / BOOKED / IN_SERVICE / UNDER_MAINTENANCE / INACTIVE
  isActive        Boolean       @default(true) @map("is_active")
  notes           String?

  createdAt       DateTime      @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime      @updatedAt @db.Timestamptz @map("updated_at")

  drivers         VehicleDriver[]
  assignments     TransportAssignment[]
  tasreehPermits  TasreehPermit[]
  routes          TransportRoute[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("vehicles")
  @@schema("plugin_transport")
}

model Driver {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid @map("tenant_id")
  vendorId        String?  @db.Uuid @map("vendor_id")
  firstName       String   @db.VarChar(100) @map("first_name")
  lastName        String   @db.VarChar(100) @map("last_name")
  phone           String   @db.VarChar(30)
  email           String?  @db.VarChar(255)
  nationality     String?  @db.Char(2)
  idNumber        String?  @db.VarChar(50) @map("id_number")
  languages       String[]  // iso codes
  licenseNumber   String?  @db.VarChar(50) @map("license_number")
  licenseExpiry   DateTime? @db.Date @map("license_expiry")
  photoUrl        String?  @map("photo_url")
  documentUrls    String[] @map("document_urls")
  status          String   @db.VarChar(20) @default("AVAILABLE")  // AVAILABLE / ASSIGNED / ON_TRIP / OFF_DUTY / INACTIVE
  rating          Decimal? @db.Decimal(3,2)
  isActive        Boolean  @default(true) @map("is_active")
  notes           String?

  createdAt       DateTime @default(now()) @db.Timestamptz @map("created_at")

  vehicles        VehicleDriver[]
  routes          TransportRoute[]
  assignments     TransportAssignment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("drivers")
  @@schema("plugin_transport")
}

model VehicleDriver {
  vehicleId  String   @db.Uuid @map("vehicle_id")
  driverId   String   @db.Uuid @map("driver_id")
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  driver     Driver   @relation(fields: [driverId], references: [id])
  isPrimary  Boolean  @default(false) @map("is_primary")
  assignedAt DateTime @default(now()) @db.Timestamptz @map("assigned_at")

  @@id([vehicleId, driverId])
  @@map("vehicle_drivers")
  @@schema("plugin_transport")
}

model TransportRoute {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String       @db.Uuid @map("tenant_id")
  name         String       @db.VarChar(200)
  movementType MovementType @map("movement_type")
  originCity   String       @db.VarChar(100) @map("origin_city")
  destCity     String       @db.VarChar(100) @map("dest_city")
  pickupPoint  String?      @db.VarChar(255) @map("pickup_point")
  dropoffPoint String?      @db.VarChar(255) @map("dropoff_point")
  distanceKm   Int?         @map("distance_km")
  durationMins Int?         @map("duration_mins")
  departureAt  DateTime?    @db.Timestamptz @map("departure_at")
  arrivalAt    DateTime?    @db.Timestamptz @map("arrival_at")
  pricePerSeatCents BigInt? @map("price_per_seat_cents")
  pricePerVehicleCents BigInt? @map("price_per_vehicle_cents")
  currency     String       @default("SAR") @db.VarChar(8)
  totalSeats   Int?         @map("total_seats")
  bookedSeats  Int          @default(0) @map("booked_seats")
  vehicleId    String?      @db.Uuid @map("vehicle_id")
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id])
  driverId     String?      @db.Uuid @map("driver_id")
  driver       Driver?      @relation(fields: [driverId], references: [id])
  status       String       @db.VarChar(20) @default("ACTIVE")  // DRAFT / ACTIVE / FULLY_BOOKED / COMPLETED / CANCELLED / INACTIVE
  notes        String?

  createdAt    DateTime     @default(now()) @db.Timestamptz @map("created_at")
  updatedAt    DateTime     @default(now()) @updatedAt @db.Timestamptz @map("updated_at")

  assignments  TransportAssignment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("transport_routes")
  @@schema("plugin_transport")
}

model TransportAssignment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid @map("tenant_id")
  vehicleId     String   @db.Uuid @map("vehicle_id")
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])
  routeId       String?  @db.Uuid @map("route_id")
  route         TransportRoute? @relation(fields: [routeId], references: [id])
  driverId      String?  @db.Uuid @map("driver_id")
  driver        Driver?  @relation(fields: [driverId], references: [id])
  groupId       String?  @db.Uuid @map("group_id")
  bookingId     String?  @db.Uuid @map("booking_id")

  customerType  String   @db.VarChar(20) @default("PLATFORM_USER") @map("customer_type")  // PLATFORM_USER / OPERATOR / EXTERNAL
  customerName  String?  @db.VarChar(200) @map("customer_name")
  customerEmail String?  @db.VarChar(255) @map("customer_email")
  customerPhone String?  @db.VarChar(40) @map("customer_phone")

  pickupLocation  String? @db.VarChar(255) @map("pickup_location")
  dropoffLocation String? @db.VarChar(255) @map("dropoff_location")

  scheduledAt   DateTime @db.Timestamptz @map("scheduled_at")
  departedAt    DateTime? @db.Timestamptz @map("departed_at")
  arrivedAt     DateTime? @db.Timestamptz @map("arrived_at")
  pilgrims      Json     @default("[]") @db.JsonB
  passengerCount Int     @default(1) @map("passenger_count")

  priceCents    BigInt   @default(0) @map("price_cents")
  currency      String   @default("SAR") @db.VarChar(8)
  paymentStatus String   @db.VarChar(20) @default("UNPAID") @map("payment_status")  // UNPAID / PARTIAL / PAID / REFUNDED
  status        String   @db.VarChar(20) @default("SCHEDULED")  // DRAFT / SCHEDULED / CONFIRMED / IN_PROGRESS / COMPLETED / CANCELLED
  notes         String?

  createdAt     DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt     DateTime @updatedAt @db.Timestamptz @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("transport_assignments")
  @@schema("plugin_transport")
}

model TasreehPermit {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid @map("tenant_id")
  vehicleId    String   @db.Uuid @map("vehicle_id")
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  permitNumber String   @db.VarChar(50) @map("permit_number")
  permitDate   DateTime @db.Date @map("permit_date")
  zone         String   @db.VarChar(50)  // MINA, ARAFAT, MUZDALIFAH
  issuedAt     DateTime? @db.Timestamptz @map("issued_at")
  expiresAt    DateTime  @db.Date @map("expires_at")
  documentUrl  String?  @map("document_url")

  @@index([tenantId])
  @@map("tasreeh_permits")
  @@schema("plugin_transport")
}

// ============================================================
// PLUGIN: FINANCE
// ============================================================

model Invoice {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String        @db.Uuid @map("tenant_id")
  invoiceRef      String        @unique @map("invoice_ref")  // INV-2026-00001
  status          InvoiceStatus @default(DRAFT)
  type            String        @db.VarChar(30) @default("CUSTOMER")  // CUSTOMER / VENDOR / CREDIT_NOTE

  // Parties
  bookingId       String?       @db.Uuid @map("booking_id")
  pilgrimId       String?       @db.Uuid @map("pilgrim_id")
  vendorId        String?       @db.Uuid @map("vendor_id")
  issuedToName    String        @map("issued_to_name")
  issuedToAddress Json?         @db.JsonB @map("issued_to_address")

  // Amounts (all bigint minor units)
  subtotalCents   BigInt        @map("subtotal_cents")
  taxCents        BigInt        @default(0) @map("tax_cents")
  discountCents   BigInt        @default(0) @map("discount_cents")
  totalCents      BigInt        @map("total_cents")
  paidCents       BigInt        @default(0) @map("paid_cents")
  currency        String        @db.Char(3) @default("SAR")

  // Dates
  issuedAt        DateTime?     @db.Date @map("issued_at")
  dueAt           DateTime?     @db.Date @map("due_at")
  paidAt          DateTime?     @db.Timestamptz @map("paid_at")

  // ZATCA fields (for KSA e-invoicing)
  zatcaUuid       String?       @db.Uuid @map("zatca_uuid")
  zatcaHash       String?       @map("zatca_hash")
  zatcaQrCode     String?       @map("zatca_qr_code")
  zatcaClearedAt  DateTime?     @db.Timestamptz @map("zatca_cleared_at")

  lineItems       Json          @default("[]") @db.JsonB @map("line_items")
  notes           String?

  createdAt       DateTime      @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime      @updatedAt @db.Timestamptz @map("updated_at")
  createdBy       String?       @db.Uuid @map("created_by")

  payments        Payment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([invoiceRef])
  @@map("invoices")
  @@schema("plugin_finance")
}

model Payment {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String        @db.Uuid @map("tenant_id")
  invoiceId       String?       @db.Uuid @map("invoice_id")
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id])
  bookingId       String?       @db.Uuid @map("booking_id")
  pilgrimId       String?       @db.Uuid @map("pilgrim_id")
  status          PaymentStatus @default(PENDING)

  // Amount
  amountCents     BigInt        @map("amount_cents")
  currency        String        @db.Char(3)
  fxRateSar       Decimal?      @db.Decimal(15,6) @map("fx_rate_sar")  // rate to SAR at time of payment

  // Gateway
  gateway         String        @db.VarChar(50)  // stripe, hyperpay, midtrans, tabby, tamara, cash
  gatewayRef      String?       @db.VarChar(200) @map("gateway_ref")
  gatewayStatus   String?       @db.VarChar(50)  @map("gateway_status")
  gatewayResponse Json?         @db.JsonB @map("gateway_response")

  // BNPL
  isBnpl          Boolean       @default(false) @map("is_bnpl")
  bnplProvider    String?       @db.VarChar(50) @map("bnpl_provider")
  installmentPlan Json?         @db.JsonB @map("installment_plan")

  idempotencyKey  String        @unique @map("idempotency_key")
  paidAt          DateTime?     @db.Timestamptz @map("paid_at")
  failedAt        DateTime?     @db.Timestamptz @map("failed_at")
  failureReason   String?       @map("failure_reason")
  refundedCents   BigInt        @default(0) @map("refunded_cents")
  refundedAt      DateTime?     @db.Timestamptz @map("refunded_at")

  createdAt       DateTime      @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime      @updatedAt @db.Timestamptz @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([idempotencyKey])
  @@map("payments")
  @@schema("plugin_finance")
}

model BudgetPlan {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @db.Uuid @map("tenant_id")
  planRef            String   @unique @map("plan_ref")  // BP-2026-00001

  // Client
  clientUserId       String?  @db.Uuid @map("client_user_id")
  clientName         String   @db.VarChar(200) @map("client_name")
  clientType         String   @db.VarChar(20) @default("TRAVELER") @map("client_type")  // TRAVELER / OPERATOR / EXTERNAL
  requestId          String?  @db.Uuid @map("request_id")    // optional marketplace request link

  // Trip parameters
  destination        String?  @db.VarChar(120)
  dateFrom           DateTime? @db.Date @map("date_from")
  dateTo             DateTime? @db.Date @map("date_to")
  travelers          Int      @default(1)
  currency           String   @default("SAR") @db.VarChar(8)

  // Budget breakdown (minor units)
  totalBudgetCents   BigInt   @default(0) @map("total_budget_cents")
  hotelBudgetCents   BigInt   @default(0) @map("hotel_budget_cents")
  transportBudgetCents BigInt @default(0) @map("transport_budget_cents")
  visaBudgetCents    BigInt   @default(0) @map("visa_budget_cents")
  packageBudgetCents BigInt   @default(0) @map("package_budget_cents")
  otherBudgetCents   BigInt   @default(0) @map("other_budget_cents")

  commissionRate     Decimal? @db.Decimal(5,2) @map("commission_rate")  // percent
  commissionCents    BigInt   @default(0) @map("commission_cents")

  suggestedOptions   Json     @default("[]") @db.JsonB @map("suggested_options")
  finalPlan          Json?    @db.JsonB @map("final_plan")
  status             String   @db.VarChar(20) @default("DRAFT")  // DRAFT / PROPOSED / ACCEPTED / COMPLETED / CANCELLED
  notes              String?

  createdAt          DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt          DateTime @updatedAt @db.Timestamptz @map("updated_at")
  createdBy          String?  @db.Uuid @map("created_by")

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("budget_plans")
  @@schema("plugin_finance")
}

model LedgerEntry {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
