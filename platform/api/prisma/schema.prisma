// ============================================================
// MARKETPLACE SCHEMA
// ============================================================

model Vendor {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String?      @db.Uuid @map("tenant_id")  // if linked to a tenant
  status          VendorStatus @default(PENDING_KYC)
  type            TenantType   // VENDOR_HOTEL / VENDOR_TRANSPORT / etc.

  name            String       @db.VarChar(255)
  nameAr          String?      @db.VarChar(255) @map("name_ar")
  description     String?
  email           String       @db.VarChar(255)
  phone           String?      @db.VarChar(30)
  website         String?
  country         String       @db.Char(2)
  city            String?      @db.VarChar(100)
  address         String?

  kycDocuments    Json         @default("[]") @db.JsonB @map("kyc_documents")
  verifiedAt      DateTime?    @db.Timestamptz @map("verified_at")
  verifiedBy      String?      @db.Uuid @map("verified_by")
  rating          Decimal?     @db.Decimal(3,2)
  ratingCount     Int          @default(0) @map("rating_count")

  logoUrl         String?      @map("logo_url")
  images          String[]

  createdAt       DateTime     @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime     @updatedAt @db.Timestamptz @map("updated_at")

  listings        Listing[]
  ratings         VendorRating[]
  quotes          Quote[]

  @@index([status])
  @@index([type])
  @@map("vendors")
  @@schema("marketplace")
}

model Listing {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId        String   @db.Uuid @map("vendor_id")
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  type            String   @db.VarChar(50)  // hotel_room, transport_service, guide, catering, visa_service
  name            String   @db.VarChar(255)
  nameAr          String?  @db.VarChar(255) @map("name_ar")
  description     String?
  priceCents      BigInt   @map("price_cents")
  currency        String   @db.Char(3) @default("SAR")
  pricingModel    String   @db.VarChar(30) @default("PER_PERSON")  // PER_PERSON / PER_GROUP / PER_NIGHT
  attributes      Json     @default("{}") @db.JsonB
  imageUrls       String[] @map("image_urls")
  status          String   @db.VarChar(20) @default("PUBLISHED")  // DRAFT / PUBLISHED / PAUSED / ARCHIVED
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime @updatedAt @db.Timestamptz @map("updated_at")

  quotes          Quote[]
  inquiries       ListingInquiry[]
  bookings        ListingBooking[]

  @@index([vendorId])
  @@index([type, status])
  @@map("listings")
  @@schema("marketplace")
}

model ListingInquiry {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId     String   @db.Uuid @map("listing_id")
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fromUserId    String?  @db.Uuid @map("from_user_id")
  fromName      String?  @db.VarChar(200) @map("from_name")
  fromEmail     String?  @db.VarChar(255) @map("from_email")
  fromPhone     String?  @db.VarChar(40) @map("from_phone")
  message       String
  partySize     Int?     @map("party_size")
  startDate     DateTime? @db.Date @map("start_date")
  endDate       DateTime? @db.Date @map("end_date")
  status        String   @db.VarChar(20) @default("NEW")  // NEW / RESPONDED / CONVERTED / CLOSED
  response      String?
  respondedAt   DateTime? @db.Timestamptz @map("responded_at")
  createdAt     DateTime  @default(now()) @db.Timestamptz @map("created_at")

  @@index([listingId, status])
  @@index([fromUserId])
  @@map("listing_inquiries")
  @@schema("marketplace")
}

model ListingBooking {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId       String   @db.Uuid @map("listing_id")
  listing         Listing  @relation(fields: [listingId], references: [id])
  customerUserId  String?  @db.Uuid @map("customer_user_id")
  customerName    String   @db.VarChar(200) @map("customer_name")
  customerEmail   String?  @db.VarChar(255) @map("customer_email")
  customerPhone   String?  @db.VarChar(40) @map("customer_phone")
  startDate       DateTime? @db.Date @map("start_date")
  endDate         DateTime? @db.Date @map("end_date")
  partySize       Int      @default(1) @map("party_size")
  totalAmountCents BigInt  @default(0) @map("total_amount_cents")
  currency        String   @default("SAR") @db.VarChar(8)
  status          String   @db.VarChar(20) @default("PENDING")  // PENDING / CONFIRMED / PAID / COMPLETED / CANCELLED / REFUNDED
  paymentStatus   String   @db.VarChar(20) @default("UNPAID") @map("payment_status")  // UNPAID / PARTIAL / PAID / REFUNDED
  notes           String?
  createdAt       DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime @updatedAt @db.Timestamptz @map("updated_at")

  @@index([listingId, status])
  @@index([customerUserId])
  @@map("listing_bookings")
  @@schema("marketplace")
}

model Quote {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid @map("tenant_id")  // requesting operator
  vendorId        String   @db.Uuid @map("vendor_id")
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  listingId       String?  @db.Uuid @map("listing_id")
  listing         Listing? @relation(fields: [listingId], references: [id])

  status          String   @db.VarChar(30) @default("PENDING")  // PENDING, OFFERED, ACCEPTED, REJECTED, EXPIRED
  requirements    Json     @default("{}") @db.JsonB
  offeredPriceCents BigInt? @map("offered_price_cents")
  currency        String   @db.Char(3) @default("SAR")
  validUntil      DateTime? @db.Timestamptz @map("valid_until")

  requestedAt     DateTime @default(now()) @db.Timestamptz @map("requested_at")
  respondedAt     DateTime? @db.Timestamptz @map("responded_at")
  acceptedAt      DateTime? @db.Timestamptz @map("accepted_at")
  rejectedAt      DateTime? @db.Timestamptz @map("rejected_at")
  notes           String?

  @@index([tenantId])
  @@index([vendorId])
  @@map("quotes")
  @@schema("marketplace")
}

model VendorRating {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId    String   @db.Uuid @map("vendor_id")
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  tenantId    String   @db.Uuid @map("tenant_id")  // rating operator
  bookingRef  String?  @map("booking_ref")
  score       Int      // 1-5
  review      String?
  isVerified  Boolean  @default(false) @map("is_verified")  // only operators with completed bookings
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@unique([vendorId, tenantId, bookingRef])
  @@map("vendor_ratings")
  @@schema("marketplace")
}

// ============================================================
// SOCIAL SCHEMA — Cross-tenant feed (no tenant_id RLS here)
// ============================================================

model SocialAccount {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String            @unique @db.Uuid @map("user_id")
  user            User              @relation(fields: [userId], references: [id])
  type            SocialAccountType
  displayName     String            @db.VarChar(100) @map("display_name")
  bio             String?
  avatarUrl       String?           @map("avatar_url")
  isVerified      Boolean           @default(false) @map("is_verified")
  verifiedBadge   String?           @map("verified_badge")  // operator, vendor, guide
  privacyDefault  PostVisibility    @default(PUBLIC) @map("privacy_default")
  coverUrl        String?           @map("cover_url")

  // Traveler profile fields
  phone           String?           @db.VarChar(40)
  nationality     String?           @db.Char(2)
  city            String?           @db.VarChar(100)
  travelInterests String[]          @map("travel_interests")  // ["UMRAH", "HAJJ", "FAMILY_TRIP", ...]
  preferredDateFrom DateTime?       @db.Date @map("preferred_date_from")
  preferredDateTo   DateTime?       @db.Date @map("preferred_date_to")
  profileVisibility String          @db.VarChar(20) @default("PUBLIC") @map("profile_visibility")  // PUBLIC / CONNECTIONS / PRIVATE
  contactVisibility String          @db.VarChar(20) @default("CONNECTIONS") @map("contact_visibility")  // PUBLIC / CONNECTIONS / PRIVATE

  followerCount   Int               @default(0) @map("follower_count")
  followingCount  Int               @default(0) @map("following_count")
  postCount       Int               @default(0) @map("post_count")
  isSuspended     Boolean           @default(false) @map("is_suspended")
  isShadowBanned  Boolean           @default(false) @map("is_shadow_banned")
  createdAt       DateTime          @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime          @updatedAt @db.Timestamptz @map("updated_at")

  posts           Post[]
  comments        Comment[]
  reactions       Reaction[]
  followingList   Follow[]          @relation("Follower")
  followerList    Follow[]          @relation("Followed")
  sentMessages    Message[]
  postReports     PostReport[]
  savedPosts      SavedPost[]

  @@map("social_accounts")
  @@schema("social")
}

model SavedPost {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId   String        @db.Uuid @map("account_id")
  account     SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  postId      String        @db.Uuid @map("post_id")
  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  savedAt     DateTime      @default(now()) @db.Timestamptz @map("saved_at")

  @@unique([accountId, postId])
  @@index([accountId, savedAt(sort: Desc)])
  @@map("saved_posts")
  @@schema("social")
}

model Post {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId        String           @db.Uuid @map("author_id")
  author          SocialAccount    @relation(fields: [authorId], references: [id])
  type            PostType
  visibility      PostVisibility   @default(PUBLIC)
  moderationStatus ModerationStatus @default(PENDING) @map("moderation_status")

  // Content
  body            String?          @db.VarChar(2000)
  structuredData  Json?            @db.JsonB @map("structured_data")  // offer/guideline/event fields
  mediaUrls       String[]         @map("media_urls")
  attachmentUrl   String?          @map("attachment_url")   // PDF for guidelines
  tags            String[]
  language        String           @default("ar") @db.VarChar(10)

  // Expiry (for offers, stories)
  expiresAt       DateTime?        @db.Timestamptz @map("expires_at")

  // Engagement counts (denormalized for perf)
  likeCount       Int              @default(0) @map("like_count")
  commentCount    Int              @default(0) @map("comment_count")
  shareCount      Int              @default(0) @map("share_count")
  saveCount       Int              @default(0) @map("save_count")

  // Source
  sourceCountry   String?          @db.Char(2) @map("source_country")
  targetRoles     String[]         @map("target_roles")  // for role-set visibility

  // Moderation
  moderatedAt     DateTime?        @db.Timestamptz @map("moderated_at")
  moderatedBy     String?          @db.Uuid @map("moderated_by")
  moderationNotes String?          @map("moderation_notes")

  createdAt       DateTime         @default(now()) @db.Timestamptz @map("created_at")
  updatedAt       DateTime         @updatedAt @db.Timestamptz @map("updated_at")
  deletedAt       DateTime?        @db.Timestamptz @map("deleted_at")

  comments        Comment[]
  reactions       Reaction[]
  reports         PostReport[]
  savedBy         SavedPost[]

  @@index([authorId])
  @@index([type, moderationStatus])
  @@index([createdAt])
  @@map("posts")
  @@schema("social")
}

model Comment {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId      String        @db.Uuid @map("post_id")
  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String        @db.Uuid @map("author_id")
  author      SocialAccount @relation(fields: [authorId], references: [id])
  parentId    String?       @db.Uuid @map("parent_id")
  body        String        @db.VarChar(1000)
  likeCount   Int           @default(0) @map("like_count")
  moderationStatus ModerationStatus @default(APPROVED) @map("moderation_status")
  createdAt   DateTime      @default(now()) @db.Timestamptz @map("created_at")
  deletedAt   DateTime?     @db.Timestamptz @map("deleted_at")

  reactions   Reaction[]

  @@index([postId])
  @@index([authorId])
  @@map("comments")
  @@schema("social")
}

model Reaction {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId   String        @db.Uuid @map("account_id")
  account     SocialAccount @relation(fields: [accountId], references: [id])
  postId      String?       @db.Uuid @map("post_id")
  post        Post?         @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId   String?       @db.Uuid @map("comment_id")
  comment     Comment?      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  type        String        @db.VarChar(20) @default("LIKE")  // LIKE, SAVE, SHARE
  createdAt   DateTime      @default(now()) @db.Timestamptz @map("created_at")

  @@unique([accountId, postId, type])
  @@unique([accountId, commentId, type])
  @@map("reactions")
  @@schema("social")
}

model Follow {
  followerId  String        @db.Uuid @map("follower_id")
  followedId  String        @db.Uuid @map("followed_id")
  follower    SocialAccount @relation("Follower", fields: [followerId], references: [id])
  followed    SocialAccount @relation("Followed", fields: [followedId], references: [id])
  createdAt   DateTime      @default(now()) @db.Timestamptz @map("created_at")

  @@id([followerId, followedId])
  @@map("follows")
  @@schema("social")
}

model Conversation {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type         String   @db.VarChar(20) @default("DM")  // DM, GROUP, BOOKING_THREAD, TRIP_THREAD
  name         String?  @db.VarChar(200)
  contextRef   String?  @db.VarChar(100) @map("context_ref")  // booking_id, trip_id
  participants Json     @default("[]") @db.JsonB  // account IDs
  lastMessageAt DateTime? @db.Timestamptz @map("last_message_at")
  createdAt    DateTime @default(now()) @db.Timestamptz @map("created_at")

  messages     Message[]

  @@map("conversations")
  @@schema("social")
}

model Message {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String        @db.Uuid @map("conversation_id")
  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  senderId       String        @db.Uuid @map("sender_id")
  sender         SocialAccount @relation(fields: [senderId], references: [id])
  body           String        @db.VarChar(4000)
  mediaUrls      String[]      @map("media_urls")
  readBy         Json          @default("[]") @db.JsonB @map("read_by")  // [{account_id, read_at}]
  deletedAt      DateTime?     @db.Timestamptz @map("deleted_at")
  createdAt      DateTime      @default(now()) @db.Timestamptz @map("created_at")

  @@index([conversationId, createdAt])
  @@map("messages")
  @@schema("social")
}

model PostReport {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId      String        @db.Uuid @map("post_id")
  post        Post          @relation(fields: [postId], references: [id])
  reporterId  String        @db.Uuid @map("reporter_id")
  reporter    SocialAccount @relation(fields: [reporterId], references: [id])
  reason      String        @db.VarChar(50)
  details     String?
  resolvedAt  DateTime?     @db.Timestamptz @map("resolved_at")
  resolvedBy  String?       @db.Uuid @map("resolved_by")
  resolution  String?       @db.VarChar(50)  // REMOVED, NO_ACTION, SHADOW_BAN, SUSPEND
  createdAt   DateTime      @default(now()) @db.Timestamptz @map("created_at")

  @@map("post_reports")
  @@schema("social")
}

// ─── Connection (friend) — bidirectional, requires accept ────────────────
enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED

  @@schema("social")
}

model Connection {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterId  String           @db.Uuid @map("requester_id")
  recipientId  String           @db.Uuid @map("recipient_id")
  status       ConnectionStatus @default(PENDING)
  message      String?
  respondedAt  DateTime?        @db.Timestamptz @map("responded_at")
  createdAt    DateTime         @default(now()) @db.Timestamptz @map("created_at")
  updatedAt    DateTime         @updatedAt @db.Timestamptz @map("updated_at")

  @@unique([requesterId, recipientId])
  @@index([requesterId])
  @@index([recipientId, status])
  @@map("connections")
  @@schema("social")
}

// ─── Notification — in-app, per-user ─────────────────────────────────────
enum NotificationType {
  POST_COMMENT
  POST_REACTION
  COMMENT_REPLY
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  FOLLOW
  MESSAGE
  REQUEST_OFFER
  REQUEST_OFFER_ACCEPTED
  REQUEST_OFFER_REJECTED
  GROUP_INVITE
  BOOKING_CREATED
  BOOKING_STATUS
  PAYMENT_RECEIVED
  VISA_STATUS
  SYSTEM

  @@schema("social")
}

model Notification {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String?          @db.Uuid @map("tenant_id")
  recipientId String           @db.Uuid @map("recipient_id")     // user.id (not SocialAccount.id)
  actorId     String?          @db.Uuid @map("actor_id")         // user.id who triggered it
  type        NotificationType
  title       String           @db.VarChar(200)
  body        String?
  link        String?                                            // /social/posts/:id, /messages/:id
  data        Json?            @db.JsonB
  readAt      DateTime?        @db.Timestamptz @map("read_at")
  createdAt   DateTime         @default(now()) @db.Timestamptz @map("created_at")

  @@index([recipientId, readAt])
  @@index([recipientId, createdAt(sort: Desc)])
  @@map("notifications")
  @@schema("social")
}

// ─── Public website inquiries (contact / partner / careers / newsletter / demo) ──
enum InquiryType {
  CONTACT
  PARTNER
  CAREERS
  NEWSLETTER
  DEMO
  SUPPORT

  @@schema("core")
}

enum InquiryStatus {
  NEW
  IN_REVIEW
  RESOLVED
  ARCHIVED

  @@schema("core")
}

model PublicInquiry {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type      InquiryType
  status    InquiryStatus @default(NEW)
  name      String?       @db.VarChar(160)
  email     String        @db.VarChar(200)
  phone     String?       @db.VarChar(40)
  company   String?       @db.VarChar(200)
  subject   String?       @db.VarChar(240)
  message   String?
  metadata  Json?         @db.JsonB   // role interest, position applied for, source page, etc.
  createdAt DateTime      @default(now()) @db.Timestamptz @map("created_at")
  updatedAt DateTime      @updatedAt @db.Timestamptz @map("updated_at")

  @@index([type, status])
  @@index([createdAt(sort: Desc)])
  @@map("public_inquiries")
  @@schema("core")
}

// ─── Marketplace Request (traveler-side) + Offer (provider-side) ─────────
enum RequestStatus {
  OPEN
  IN_NEGOTIATION
  FULFILLED
  CLOSED
  EXPIRED

  @@schema("marketplace")
}

enum RequestServiceType {
  HOTEL
  TRANSPORT
  VISA
  PACKAGE
  GUIDE
  CATERING
  OTHER

  @@schema("marketplace")
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN

  @@schema("marketplace")
}

model MarketplaceRequest {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String              @db.Uuid @map("tenant_id")
  travelerId    String              @db.Uuid @map("traveler_id")  // user.id
  serviceType   RequestServiceType  @map("service_type")
  title         String              @db.VarChar(200)
  description   String?
  city          String?
  dateFrom      DateTime?           @db.Timestamptz @map("date_from")
  dateTo        DateTime?           @db.Timestamptz @map("date_to")
  travelers     Int                 @default(1)
  budgetMinCents BigInt?            @map("budget_min_cents")
  budgetMaxCents BigInt?            @map("budget_max_cents")
  currency      String              @default("SAR") @db.VarChar(8)
  requirements  Json?               @db.JsonB
  status        RequestStatus       @default(OPEN)
  acceptedOfferId String?           @db.Uuid @map("accepted_offer_id")
  expiresAt     DateTime?           @db.Timestamptz @map("expires_at")
  createdAt     DateTime            @default(now()) @db.Timestamptz @map("created_at")
  updatedAt     DateTime            @updatedAt @db.Timestamptz @map("updated_at")

  offers        RequestOffer[]

  @@index([tenantId, status])
  @@index([travelerId, status])
  @@index([serviceType, status])
  @@map("marketplace_requests")
  @@schema("marketplace")
}

model RequestOffer {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId   String             @db.Uuid @map("request_id")
  request     MarketplaceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  providerId  String             @db.Uuid @map("provider_id")    // user.id of provider
  vendorId    String?            @db.Uuid @map("vendor_id")      // optional link to marketplace.Vendor
  title       String             @db.VarChar(200)
  description String?
  priceCents  BigInt             @map("price_cents")
  currency    String             @default("SAR") @db.VarChar(8)
  validUntil  DateTime?          @db.Timestamptz @map("valid_until")
  status      OfferStatus        @default(PENDING)
  respondedAt DateTime?          @db.Timestamptz @map("responded_at")
  createdAt   DateTime           @default(now()) @db.Timestamptz @map("created_at")
  updatedAt   DateTime           @updatedAt @db.Timestamptz @map("updated_at")

  @@index([requestId, status])
  @@index([providerId, status])
  @@map("request_offers")
  @@schema("marketplace")
}

// ============================================================
// AUDIT SCHEMA — Immutable event log
// ============================================================

model AuditLog {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String?     @db.Uuid @map("tenant_id")
  actorId     String?     @db.Uuid @map("actor_id")
  actorEmail  String?     @map("actor_email")
  action      AuditAction
  namespace   String      @db.VarChar(50)   // plugin namespace
  resource    String      @db.VarChar(100)
  resourceId  String?     @map("resource_id")
  beforeState Json?       @db.JsonB @map("before_state")
  afterState  Json?       @db.JsonB @map("after_state")
  metadata    Json?       @db.JsonB
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  requestId   String?     @map("request_id")
  occurredAt  DateTime    @default(now()) @db.Timestamptz @map("occurred_at")

  @@index([tenantId, occurredAt])
  @@index([actorId])
  @@index([resource, resourceId])
  @@map("audit_logs")
  @@schema("audit")
}
