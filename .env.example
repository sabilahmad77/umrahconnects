# ============================================================
# Umrah Connects — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
ADMIN_URL=http://localhost:3001

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=umrah_connects
POSTGRES_USER=umrah
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=umrah-connects-api
KAFKA_GROUP_ID=umrah-connects-consumer

# --- JWT ---
JWT_SECRET=replace_with_256_bit_secret
JWT_REFRESH_SECRET=replace_with_different_256_bit_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Auth / OIDC ---
NEXTAUTH_SECRET=replace_with_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# --- AWS ---
AWS_REGION=me-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=umrah-connects-documents
AWS_KMS_KEY_ID=

# --- MinIO (local S3 replacement for dev) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=umrah-connects-documents

# --- Email ---
SENDGRID_API_KEY=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@umrahconnects.io

# --- WhatsApp Business API ---
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
THREESIXTY_DIALOG_API_KEY=

# --- SMS ---
TWILIO_SMS_FROM=

# --- Payment Gateways ---
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
HYPERPAY_ACCESS_TOKEN=
HYPERPAY_ENTITY_ID=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SANDBOX=true
TABBY_API_KEY=
TAMARA_API_KEY=
TAMARA_MERCHANT_TOKEN=

# --- Regulator Integrations ---
NUSUK_API_BASE=https://api.nusuk.sa
NUSUK_API_KEY=
NUSUK_OPERATOR_ID=
SISKOPATUH_API_BASE=https://siskopatuh.kemenag.go.id
SISKOPATUH_API_KEY=
NAHCON_API_BASE=https://api.nahcon.gov.ng
NAHCON_API_KEY=

# --- ZATCA (e-invoicing) ---
ZATCA_PROVIDER=wafeq
WAFEQ_API_KEY=

# --- Observability ---
DATADOG_API_KEY=
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Encryption ---
FIELD_ENCRYPTION_KEY=replace_with_32_byte_hex_key
